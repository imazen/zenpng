Cargo.lock
.github/workflows/ci.yml.bak

# === Standard exclusions (do not depend on user ~/.gitignore) ===

# Rust build artifacts
target/

# Fuzz build artifacts and crashes
fuzz/target/
fuzz/artifacts/
fuzz/corpus/
fuzz/coverage/
fuzz-*.log
*.profraw
*.profdata

# Profiling
perf.data
perf.data.old
flamegraph.svg
heaptrack.*.zst
cachegrind.out.*
callgrind.out.*
massif.out.*

# C/C++ build artifacts
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll
*.rlib

# Compiled binaries with no extension
rust_out

# Node
node_modules/

# OS
.DS_Store
Thumbs.db

# Editors
*.swp
*.swo
*~
.idea/
.vscode/
*.iml
!fuzz/Cargo.lock

# Tooling noise
.superwork/
.claude/
copter-report/
.zenbench/
.external-cache/
Cargo.toml.original.txt
*.rs.local

.workongoing
